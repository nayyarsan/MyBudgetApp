# Normalize line endings to LF on check-in
* text=auto eol=lf

# Dart/Flutter files — always LF
*.dart text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
Makefile text eol=lf

# Binary files — no conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.jar  binary
*.keystore binary
*.apk  binary
